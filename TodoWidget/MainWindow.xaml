<Window x:Class="TodoWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TodoWidget"
        Width="420"
        Height="790"
        MinWidth="400"
        MinHeight="740"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="WindowLoaded"
        Closing="WindowClosing"
        StateChanged="WindowStateChanged">
    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#FFF7FBFF" />
        <SolidColorBrush x:Key="MutedBrush" Color="#FF95A4BA" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF63D7B0" />
        <SolidColorBrush x:Key="CardBrush" Color="#C0141D29" />
        <SolidColorBrush x:Key="CardSecondaryBrush" Color="#B5101721" />
        <SolidColorBrush x:Key="StrokeBrush" Color="#2CFFFFFF" />
        <SolidColorBrush x:Key="SubtleStrokeBrush" Color="#16FFFFFF" />

        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Bahnschrift SemiLight" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#18FFFFFF" />
            <Setter Property="BorderBrush" Value="#24FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#24FFFFFF" />
                                <Setter Property="BorderBrush" Value="#40FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2863D7B0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource ChromeButtonStyle}">
            <Setter Property="Foreground" Value="#FF08130F" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="#00000000" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="CalendarDayButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#00000000" />
            <Setter Property="BorderBrush" Value="#00000000" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TodoTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="Opacity" Value="0.42" />
                    <Setter Property="TextDecorations" Value="Strikethrough" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Border Margin="6,10,6,0"
                CornerRadius="32"
                Background="#24000000" />

        <Border x:Name="WidgetChrome"
                CornerRadius="28"
                BorderThickness="1"
                BorderBrush="{StaticResource StrokeBrush}"
                SizeChanged="WidgetChromeSizeChanged">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F0121A25" Offset="0" />
                    <GradientStop Color="#F10D141D" Offset="0.55" />
                    <GradientStop Color="#F0090E14" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Canvas IsHitTestVisible="False">
                    <Ellipse Width="200"
                             Height="200"
                             Fill="#1F63D7B0"
                             Canvas.Top="-70"
                             Canvas.Left="245">
                        <Ellipse.Effect>
                            <BlurEffect Radius="72" />
                        </Ellipse.Effect>
                    </Ellipse>
                    <Ellipse Width="180"
                             Height="180"
                             Fill="#18FFA86A"
                             Canvas.Top="520"
                             Canvas.Left="-55">
                        <Ellipse.Effect>
                            <BlurEffect Radius="82" />
                        </Ellipse.Effect>
                    </Ellipse>
                </Canvas>

                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          MouseLeftButtonDown="DragAreaMouseLeftButtonDown">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="DESKTOP TODO"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontFamily="Bahnschrift SemiLight"
                                       FontSize="12" />
                            <TextBlock Text="Tasks, calendar, and time in one widget"
                                       Margin="0,5,0,0"
                                       Foreground="#E6FFFFFF"
                                       FontSize="15"
                                       FontWeight="SemiBold" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top">
                            <Button x:Name="PinButton"
                                    Style="{StaticResource ChromeButtonStyle}"
                                    Click="PinButtonOnClick" />
                            <Button Style="{StaticResource ChromeButtonStyle}"
                                    Content="Hide"
                                    Margin="0"
                                    Click="HideButtonOnClick" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,12,0,0"
                            Padding="16"
                            CornerRadius="24"
                            BorderThickness="1"
                            BorderBrush="{StaticResource SubtleStrokeBrush}"
                            Background="#7A152030"
                            MouseLeftButtonDown="DragAreaMouseLeftButtonDown">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="LIVE CLOCK"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           FontFamily="Bahnschrift SemiLight" />
                                <StackPanel Margin="0,10,0,0"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Bottom">
                                    <TextBlock x:Name="TimeTextBlock"
                                               Foreground="{StaticResource TextBrush}"
                                               FontFamily="Bahnschrift Light"
                                               FontSize="42"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="SecondsTextBlock"
                                               Margin="8,0,0,7"
                                               VerticalAlignment="Bottom"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontFamily="Bahnschrift SemiLight"
                                               FontSize="16" />
                                </StackPanel>
                                <TextBlock x:Name="DateTextBlock"
                                           Margin="0,8,0,0"
                                           Foreground="#E5FFFFFF"
                                           FontSize="15" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Width="74"
                                    Height="74"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    CornerRadius="22"
                                    Background="#225FD7B0"
                                    BorderBrush="#24FFFFFF"
                                    BorderThickness="1">
                                <Grid>
                                    <TextBlock Text="TODAY"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#D5FFFFFF"
                                               FontFamily="Bahnschrift SemiBold"
                                               FontSize="12" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="286" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="14"
                                CornerRadius="22"
                                BorderThickness="1"
                                BorderBrush="{StaticResource SubtleStrokeBrush}"
                                Background="{StaticResource CardBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="CALENDAR"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="12"
                                                   FontFamily="Bahnschrift SemiLight" />
                                        <TextBlock x:Name="CalendarMonthTextBlock"
                                                   Margin="0,5,0,0"
                                                   Foreground="{StaticResource TextBrush}"
                                                   FontSize="22"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Style="{StaticResource ChromeButtonStyle}"
                                                Width="34"
                                                Height="32"
                                                Padding="0"
                                                Content="&lt;"
                                                Click="PreviousMonthButtonOnClick" />
                                        <Button Style="{StaticResource ChromeButtonStyle}"
                                                Width="52"
                                                Height="32"
                                                Padding="0"
                                                Margin="0,0,6,0"
                                                FontSize="11"
                                                Content="Today"
                                                Click="TodayButtonOnClick" />
                                        <Button Style="{StaticResource ChromeButtonStyle}"
                                                Width="34"
                                                Height="32"
                                                Padding="0"
                                                Margin="0"
                                                Content="&gt;"
                                                Click="NextMonthButtonOnClick" />
                                    </StackPanel>
                                </Grid>

                                <UniformGrid Grid.Row="2" Columns="7">
                                    <TextBlock Text="SUN" HorizontalAlignment="Center" Foreground="#FFFC8D8D" FontSize="10" />
                                    <TextBlock Text="MON" HorizontalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="10" />
                                    <TextBlock Text="TUE" HorizontalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="10" />
                                    <TextBlock Text="WED" HorizontalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="10" />
                                    <TextBlock Text="THU" HorizontalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="10" />
                                    <TextBlock Text="FRI" HorizontalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="10" />
                                    <TextBlock Text="SAT" HorizontalAlignment="Center" Foreground="#FF88C8FF" FontSize="10" />
                                </UniformGrid>

                                <UniformGrid x:Name="CalendarDaysGrid"
                                             Grid.Row="4"
                                             Rows="6"
                                             Columns="7" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Padding="14"
                                CornerRadius="22"
                                BorderThickness="1"
                                BorderBrush="{StaticResource SubtleStrokeBrush}"
                                Background="{StaticResource CardSecondaryBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="TASKS"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="12"
                                                   FontFamily="Bahnschrift SemiLight" />
                                        <TextBlock x:Name="SelectedDateTitleTextBlock"
                                                   Margin="0,5,0,0"
                                                   Foreground="{StaticResource TextBrush}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Padding="10,7"
                                            CornerRadius="14"
                                            Background="#1C63D7B0"
                                            BorderBrush="#24FFFFFF"
                                            BorderThickness="1">
                                        <TextBlock x:Name="TaskSummaryTextBlock"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontFamily="Bahnschrift SemiBold"
                                                   FontSize="11" />
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border CornerRadius="16"
                                            Background="#12000000"
                                            BorderBrush="#1EFFFFFF"
                                            BorderThickness="1">
                                        <Grid>
                                            <TextBox x:Name="TodoInputTextBox"
                                                     Margin="12,9"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Foreground="{StaticResource TextBrush}"
                                                     CaretBrush="{StaticResource AccentBrush}"
                                                     FontSize="13"
                                                     VerticalContentAlignment="Center"
                                                     TextChanged="TodoInputTextBoxOnTextChanged"
                                                     KeyDown="TodoInputTextBoxOnKeyDown" />
                                            <TextBlock x:Name="InputPlaceholderTextBlock"
                                                       Margin="12,9"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       FontSize="13"
                                                       IsHitTestVisible="False"
                                                       Text="Add a task for the selected day" />
                                        </Grid>
                                    </Border>

                                    <Button Grid.Column="2"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Content="Add"
                                            Click="AddTodoButtonOnClick" />
                                </Grid>

                                <Grid Grid.Row="4">
                                    <Border CornerRadius="18"
                                            Background="#0EFFFFFF"
                                            BorderBrush="#14FFFFFF"
                                            BorderThickness="1" />

                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  Padding="8">
                                        <Grid>
                                            <ItemsControl x:Name="TodoItemsControl">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,10"
                                                                Padding="12"
                                                                CornerRadius="16"
                                                                Background="#12000000"
                                                                BorderBrush="#14FFFFFF"
                                                                BorderThickness="1">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="10" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>

                                                                <CheckBox Grid.Column="0"
                                                                          VerticalAlignment="Top"
                                                                          Margin="0,2,0,0"
                                                                          IsChecked="{Binding IsCompleted, Mode=TwoWay}" />

                                                                <TextBlock Grid.Column="2"
                                                                           Style="{StaticResource TodoTitleStyle}"
                                                                           Text="{Binding Title}" />

                                                                <Button Grid.Column="3"
                                                                        Content="Delete"
                                                                        Tag="{Binding Id}"
                                                                        Style="{StaticResource ChromeButtonStyle}"
                                                                        Margin="12,0,0,0"
                                                                        Padding="10,6"
                                                                        FontSize="11"
                                                                        Click="DeleteTodoButtonOnClick" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock x:Name="EmptyStateTextBlock"
                                                       Margin="8"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Center"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       FontSize="13"
                                                       Visibility="Collapsed"
                                                       Text="No tasks saved for this day." />
                                        </Grid>
                                    </ScrollViewer>
                                </Grid>

                                <Grid Grid.Row="6" Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Opacity"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="11" />
                                        <Slider x:Name="OpacitySlider"
                                                Width="72"
                                                Margin="8,0,0,0"
                                                Minimum="0.55"
                                                Maximum="1.00"
                                                Value="0.96"
                                                SmallChange="0.01"
                                                LargeChange="0.05"
                                                ValueChanged="OpacitySliderOnValueChanged" />
                                        <TextBlock x:Name="OpacityValueTextBlock"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>

                                    <Button x:Name="StartupButton"
                                            Grid.Column="1"
                                            Style="{StaticResource ChromeButtonStyle}"
                                            Padding="10,6"
                                            FontSize="11"
                                            Click="StartupButtonOnClick" />

                                    <Button x:Name="OpenDataButton"
                                            Grid.Column="2"
                                            Style="{StaticResource ChromeButtonStyle}"
                                            Content="Data"
                                            Padding="10,6"
                                            FontSize="11"
                                            Margin="8,0,0,0"
                                            Click="OpenDataButtonOnClick" />

                                    <Button Grid.Column="3"
                                            Style="{StaticResource ChromeButtonStyle}"
                                            Content="Clear"
                                            Padding="10,6"
                                            FontSize="11"
                                            Margin="8,0,0,0"
                                            Click="ClearCompletedButtonOnClick" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
